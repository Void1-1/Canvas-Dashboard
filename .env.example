# Required — sign and verify session JWTs (min 32 chars; use a 64-char hex string)
JWT_SECRET=your-jwt-secret

# Required — AES-256-GCM key for encrypting Canvas API tokens at rest (64-char hex string = 32 bytes)
CANVAS_ENCRYPTION_KEY=your-canvas-encryption-key

# Optional — Canvas OAuth2 developer key (both must be set to enable OAuth mode; omit for manual token mode)
CANVAS_CLIENT_ID=your-canvas-client-id
CANVAS_CLIENT_SECRET=your-canvas-client-secret

# Optional — public base URL used for OAuth redirect URIs and logout redirects (defaults to http://localhost:3000)
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Optional — full path to SQLite database file (defaults to <cwd>/data/canvas-dashboard.db)
SQLITE_DB_PATH=

# Optional — set to "true" only when running behind a reverse proxy (nginx, Caddy) that sets x-forwarded-for
# Enables accurate IP logging in audit events and rate limiting; leave unset for direct-to-internet deployments
TRUST_PROXY=

# Optional — absolute path to a file where audit log JSON lines are appended for persistent storage
# If unset, audit events are only written to stdout. Recommended for production deployments.
# Example: AUDIT_LOG_FILE=/var/log/canvas-dashboard/audit.log
AUDIT_LOG_FILE=
